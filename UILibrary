        function SectionAPI:AddDropdown(dopts)
            dopts = dopts or {}
            local name = dopts.Name or "Dropdown"
            local items = dopts.Items or {}
            local default = dopts.Default or (items[1] or "Select...")
            local callback = dopts.Callback or function() end

            local selected = default
            local isOpen = false

            local evObj = {
                _callbacks = {},
                Connect = function(self2, fn)
                    table.insert(self2._callbacks, fn)
                    return { Disconnect = function() end }
                end,
                Fire = function(self2, val)
