                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = container
                })
            end

            -- Track
            local track = Create("Frame", {
                Name = "Track",
                BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
                Size = UDim2.new(0, 40, 0, 22),
                Position = UDim2.new(1, -52, 0.5, -11),
                Parent = container
            })
            MakeCorner(11, track)

            -- Thumb
            local thumb = Create("Frame", {
                Name = "Thumb",
                BackgroundColor3 = Theme.White,
                Size = UDim2.new(0, 16, 0, 16),
                Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
                Parent = track
            })
            MakeCorner(8, thumb)

            local function setToggle(val, silent)
                state = val
                Tween(track, { BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff }, 0.25, Enum.EasingStyle.Expo)
                Tween(thumb, { Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8) }, 0.25, Enum.EasingStyle.Expo)
                if not silent then
                    ToggleObj.Changed:Fire(state)
                    task.spawn(callback, state)
                end
            end

            setToggle(default, true)

            local clickArea = Create("TextButton", {
                Name = "Click",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Text = "",
                Parent = container
            })

            clickArea.MouseButton1Click:Connect(function()
                setToggle(not state)
            end)

            container.MouseEnter:Connect(function()
                Tween(container, { BackgroundColor3 = Theme.SurfaceHover }, 0.15)
            end)
            container.MouseLeave:Connect(function()
                Tween(container, { BackgroundColor3 = Theme.SurfaceAlt }, 0.15)
            end)

            function ToggleObj:SetValue(val)
                setToggle(val, true)
            end
            function ToggleObj:GetValue()
                return state
            end

            ToggleObj.Changed = {
                _callbacks = {},
                Connect = function(self2, fn)
                    table.insert(self2._callbacks, fn)
                    return { Disconnect = function() end }
                end,
                Fire = function(self2, val)
                    for _, fn in ipairs(self2._callbacks) do
                        task.spawn(fn, val)
                    end
                end
            }

            -- Re-link event correctly
            local evObj = {
                _callbacks = {},
                Connect = function(self2, fn)
                    table.insert(self2._callbacks, fn)
                    return { Disconnect = function() end }
                end,
                Fire = function(self2, val)
                    for _, fn in ipairs(self2._callbacks) do task.spawn(fn, val) end
                end
            }
            ToggleObj.Changed = evObj

            setToggle = function(val, silent)
                state = val
                Tween(track, { BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff }, 0.25, Enum.EasingStyle.Expo)
                Tween(thumb, { Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8) }, 0.25, Enum.EasingStyle.Expo)
                if not silent then
                    evObj:Fire(state)
                    task.spawn(callback, state)
                end
            end

            setToggle(default, true)
            clickArea.MouseButton1Click:Connect(function()
                setToggle(not state)
            end)

            function ToggleObj:SetValue(val)
                setToggle(val, true)
            end

            return ToggleObj
        end

        -- ========== SLIDER ==========
        function SectionAPI:AddSlider(sopts)
            sopts = sopts or {}
            local name = sopts.Name or "Slider"
            local min = sopts.Min or 0
            local max = sopts.Max or 100
            local default = sopts.Default or min
            local suffix = sopts.Suffix or ""
            local callback = sopts.Callback or function() end
            local decimals = sopts.Decimals or 0

            local value = math.clamp(default, min, max)

            local evObj = {
                _callbacks = {},
                Connect = function(self2, fn)
                    table.insert(self2._callbacks, fn)
                    return { Disconnect = function() end }
                end,
                Fire = function(self2, val)
                    for _, fn in ipairs(self2._callbacks) do task.spawn(fn, val) end
                end
            }

            local SliderObj = { Changed = evObj }

            local container = Create("Frame", {
                Name = "SliderContainer",
                BackgroundColor3 = Theme.SurfaceAlt,
                Size = UDim2.new(1, 0, 0, 58),
                LayoutOrder = self:_nextOrder(),
                Parent = self._frame
            })
            MakeCorner(8, container)
            MakeStroke(Theme.Border, 1, container)
            MakePadding(8, 8, 12, 12, container)

            Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 6),
                Parent = container
            })

            local topRow = Create("Frame", {
                Name = "TopRow",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 18),
                LayoutOrder = 1,
                Parent = container
            })

            Create("TextLabel", {
                Name = "SliderLabel",
                BackgroundTransparency = 1,
                Size = UDim2.new(0.7, 0, 1, 0),
                Text = name,
                TextColor3 = Theme.Text,
                Font = Enum.Font.GothamBold,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = topRow
            })

            local valLabel = Create("TextLabel", {
                Name = "Value",
                BackgroundTransparency = 1,
                Size = UDim2.new(0.3, 0, 1, 0),
                Position = UDim2.new(0.7, 0, 0, 0),
                Text = tostring(value) .. suffix,
                TextColor3 = Theme.Accent,
                Font = Enum.Font.GothamBold,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = topRow
            })

            -- Track
            local trackFrame = Create("Frame", {
                Name = "TrackFrame",
                BackgroundColor3 = Theme.Border,
                Size = UDim2.new(1, 0, 0, 6),
                LayoutOrder = 2,
                Parent = container
            })
            MakeCorner(3, trackFrame)

            local fill = Create("Frame", {
                Name = "Fill",
                BackgroundColor3 = Theme.Accent,
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                Parent = trackFrame
            })
            MakeCorner(3, fill)

            local thumb = Create("Frame", {
                Name = "Thumb",
                BackgroundColor3 = Theme.White,
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7),
                ZIndex = 2,
                Parent = trackFrame
            })
            MakeCorner(7, thumb)
            MakeStroke(Theme.Accent, 2, thumb)

            local dragging = false

            local function updateSlider(inputPos)
                local abs = trackFrame.AbsolutePosition
                local size = trackFrame.AbsoluteSize
                local rel = math.clamp((inputPos.X - abs.X) / size.X, 0, 1)
                local raw = min + (max - min) * rel
                local factor = 10 ^ decimals
                value = math.floor(raw * factor + 0.5) / factor
                value = math.clamp(value, min, max)

                local pct = (value - min) / (max - min)
                Tween(fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05, Enum.EasingStyle.Linear)
                Tween(thumb, { Position = UDim2.new(pct, -7, 0.5, -7) }, 0.05, Enum.EasingStyle.Linear)
                valLabel.Text = tostring(value) .. suffix
                evObj:Fire(value)
                task.spawn(callback, value)
            end

            trackFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    updateSlider(input.Position)
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                or input.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(input.Position)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)

            container.MouseEnter:Connect(function()
                Tween(container, { BackgroundColor3 = Theme.SurfaceHover }, 0.15)
            end)
            container.MouseLeave:Connect(function()
                Tween(container, { BackgroundColor3 = Theme.SurfaceAlt }, 0.15)
            end)

            function SliderObj:SetValue(val)
                value = math.clamp(val, min, max)
                local pct = (value - min) / (max - min)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                thumb.Position = UDim2.new(pct, -7, 0.5, -7)
                valLabel.Text = tostring(value) .. suffix
            end
            function SliderObj:GetValue()
                return value
            end

            return SliderObj
        end

