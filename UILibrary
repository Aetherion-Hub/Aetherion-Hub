                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
                Parent = container
            })

            local selLabel = Create("TextLabel", {
                Name = "Selected",
                BackgroundTransparency = 1,
                Position = UDim2.new(0.45, 0, 0, 0),
                Size = UDim2.new(0.45, 0, 1, 0),
                Text = selected,
                TextColor3 = Theme.Accent,
                Font = Enum.Font.Gotham,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5,
                Parent = container
            })

            local chevron = Create("TextLabel", {
                Name = "Chevron",
                BackgroundTransparency = 1,
                Position = UDim2.new(1, -28, 0, 0),
                Size = UDim2.new(0, 24, 1, 0),
                Text = "▾",
                TextColor3 = Theme.TextMuted,
                Font = Enum.Font.GothamBold,
                TextSize = 12,
                ZIndex = 5,
                Parent = container
            })

            -- Dropdown list
            local listFrame = Create("Frame", {
                Name = "DropList",
                BackgroundColor3 = Theme.Surface,
                Size = UDim2.new(1, 0, 0, 0),
                Position = UDim2.new(0, 0, 1, 4),
                ClipsDescendants = true,
                ZIndex = 10,
                Visible = false,
                Parent = container
            })
            MakeCorner(8, listFrame)
            MakeStroke(Theme.Border, 1, listFrame)

            local listLayout = Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 2),
                Parent = listFrame
            })
            MakePadding(4, 4, 4, 4, listFrame)

            local function buildItems()
                for _, child in ipairs(listFrame:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                for i, item in ipairs(items) do
                    local itemBtn = Create("TextButton", {
                        Name = "Item_" .. i,
                        BackgroundColor3 = item == selected and Theme.AccentDim or Theme.SurfaceAlt,
                        BackgroundTransparency = item == selected and 0 or 0,
                        Size = UDim2.new(1, 0, 0, 28),
                        Text = item,
                        TextColor3 = item == selected and Theme.White or Theme.TextSecondary,
                        Font = item == selected and Enum.Font.GothamBold or Enum.Font.Gotham,
                        TextSize = 11,
                        LayoutOrder = i,
                        ZIndex = 11,
                        Parent = listFrame
                    })
                    MakeCorner(6, itemBtn)

                    itemBtn.MouseEnter:Connect(function()
                        if item ~= selected then
                            Tween(itemBtn, { BackgroundColor3 = Theme.SurfaceHover }, 0.1)
                        end
                    end)
                    itemBtn.MouseLeave:Connect(function()
                        if item ~= selected then
                            Tween(itemBtn, { BackgroundColor3 = Theme.SurfaceAlt }, 0.1)
                        end
                    end)
                    itemBtn.MouseButton1Click:Connect(function()
                        selected = item
                        selLabel.Text = selected
                        evObj:Fire(selected)
                        task.spawn(callback, selected)
                        buildItems()
                        -- Close
                        isOpen = false
                        Tween(listFrame, { Size = UDim2.new(1, 0, 0, 0) }, 0.2, Enum.EasingStyle.Expo)
                        task.delay(0.22, function() listFrame.Visible = false end)
                        Tween(chevron, { Rotation = 0 }, 0.2)
                    end)
                end

                local totalHeight = #items * 30 + 8
                listFrame.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
            end

            buildItems()

            local clickArea = Create("TextButton", {
                Name = "Click",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Text = "",
                ZIndex = 6,
                Parent = container
            })

            clickArea.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    buildItems()
                    listFrame.Visible = true
                    local targetH = math.min(#items * 30 + 8, 160)
                    Tween(listFrame, { Size = UDim2.new(1, 0, 0, targetH) }, 0.25, Enum.EasingStyle.Expo)
                    Tween(chevron, { Rotation = 180 }, 0.25)
                else
                    Tween(listFrame, { Size = UDim2.new(1, 0, 0, 0) }, 0.2, Enum.EasingStyle.Expo)
                    task.delay(0.22, function() listFrame.Visible = false end)
                    Tween(chevron, { Rotation = 0 }, 0.2)
                end
            end)

            container.MouseEnter:Connect(function()
                Tween(container, { BackgroundColor3 = Theme.SurfaceHover }, 0.15)
            end)
            container.MouseLeave:Connect(function()
                Tween(container, { BackgroundColor3 = Theme.SurfaceAlt }, 0.15)
            end)

            function DropObj:Select(val)
                selected = val
                selLabel.Text = val
                buildItems()
            end
            function DropObj:GetValue()
                return selected
            end
            function DropObj:SetItems(newItems)
                items = newItems
                buildItems()
            end

            return DropObj
        end

