        Parent = self.ScreenGui
    })
    MakeCorner(12, self.MobileBtn)
    MakeStroke(Theme.AccentDim, 1.5, self.MobileBtn)

    MakeDraggable(self.MobileBtn)

    self.MobileBtn.MouseButton1Click:Connect(function()
        self:ToggleVisible()
    end)
end

function Window:ToggleVisible()
    self.IsVisible = not self.IsVisible
    if self.IsVisible then
        self.MainFrame.Visible = true
        Tween(self.MainFrame, { BackgroundTransparency = 0 }, 0.25, Enum.EasingStyle.Expo)
        for _, desc in ipairs(self.MainFrame:GetDescendants()) do
            if desc:IsA("TextLabel") or desc:IsA("TextButton") then
                Tween(desc, { TextTransparency = 0 }, 0.25)
            end
            if desc:IsA("Frame") or desc:IsA("ScrollingFrame") then
                Tween(desc, { BackgroundTransparency = desc:GetAttribute("BaseTransparency") or 0 }, 0.25)
            end
        end
    else
        Tween(self.MainFrame, { BackgroundTransparency = 1 }, 0.25)
        task.delay(0.3, function()
            self.MainFrame.Visible = false
        end)
    end
end

function Window:ToggleMinimize()
    if self.IsMinimized then
        -- Restore
        self.IsMinimized = false
        Tween(self.MainFrame, { Size = self.Size }, 0.4, Enum.EasingStyle.Expo)
        Tween(self.AccentLine, { Size = UDim2.new(1, 0, 0, 2) }, 0.35, Enum.EasingStyle.Expo)
        task.delay(0.15, function()
            Tween(self.ContentArea, { BackgroundTransparency = 0 }, 0.25)
            for _, child in ipairs(self.ContentArea:GetDescendants()) do
                if child:IsA("TextLabel") then
                    Tween(child, { TextTransparency = 0 }, 0.25)
                end
            end
            self.ContentArea.Visible = true
        end)
        self.MinBtn.Text = "─"
    else
        -- Minimize
        self.IsMinimized = true
        Tween(self.ContentArea, { BackgroundTransparency = 1 }, 0.2)
        for _, child in ipairs(self.ContentArea:GetDescendants()) do
            if child:IsA("TextLabel") then
                Tween(child, { TextTransparency = 1 }, 0.15)
            end
        end
        task.delay(0.18, function()
            self.ContentArea.Visible = false
            Tween(self.MainFrame, { Size = self.MinimizedSize }, 0.4, Enum.EasingStyle.Expo)
            Tween(self.AccentLine, { Size = UDim2.new(0.3, 0, 0, 2) }, 0.4, Enum.EasingStyle.Expo)
        end)
        self.MinBtn.Text = "□"
    end
end

function Window:SetTheme(accentColor)
    Theme.Accent = accentColor
    Theme.AccentHover = Color3.new(
        math.min(accentColor.R + 0.08, 1),
        math.min(accentColor.G + 0.08, 1),
        math.min(accentColor.B + 0.08, 1)
    )
    Theme.AccentDim = Color3.new(accentColor.R * 0.65, accentColor.G * 0.65, accentColor.B * 0.65)
    Tween(self.AccentLine, { BackgroundColor3 = accentColor }, 0.3)
    if self.MobileBtn then
        Tween(self.MobileBtn, { BackgroundColor3 = accentColor }, 0.3)
    end
    self.Accent = accentColor
end

function Window:Notify(opts)
    SendNotification(opts)
end

