function Window:_SetupControls()
    -- Minimize
    self.MinBtn.MouseButton1Click:Connect(function()
        self:ToggleMinimize()
    end)

    self.MinBtn.MouseEnter:Connect(function()
        Tween(self.MinBtn, { BackgroundColor3 = Theme.SurfaceHover }, 0.15)
    end)
    self.MinBtn.MouseLeave:Connect(function()
        Tween(self.MinBtn, { BackgroundColor3 = Theme.SurfaceAlt }, 0.15)
    end)

    -- Close
    self.CloseBtn.MouseButton1Click:Connect(function()
        Tween(self.MainFrame, { BackgroundTransparency = 1 }, 0.3)
        Tween(self.MainFrame, { Size = UDim2.new(0, self.MainFrame.AbsoluteSize.X, 0, 0) }, 0.3, Enum.EasingStyle.Expo)
        task.delay(0.35, function()
            self.ScreenGui:Destroy()
        end)
    end)

    self.CloseBtn.MouseEnter:Connect(function()
        Tween(self.CloseBtn, { BackgroundColor3 = Theme.Error, TextColor3 = Theme.White }, 0.15)
    end)
    self.CloseBtn.MouseLeave:Connect(function()
        Tween(self.CloseBtn, { BackgroundColor3 = Theme.SurfaceAlt, TextColor3 = Theme.TextSecondary }, 0.15)
    end)
end

function Window:_SetupKeybind()
    table.insert(self.Connections, UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == self.Keybind then
            self:ToggleVisible()
        end
    end))
end

function Window:_SetupMobileButton()
    local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

    self.MobileBtn = Create("TextButton", {
        Name = "MobileToggle",
