local function SendNotification(opts)
    opts = opts or {}
    local title = opts.Title or "Notification"
    local desc = opts.Description or ""
    local duration = opts.Duration or 4
    local ntype = opts.Type or "info"

    local accentColor = ntype == "success" and Theme.Success
        or ntype == "warning" and Theme.Warning
        or ntype == "error" and Theme.Error
        or Theme.Accent

    NotificationCount = NotificationCount + 1

    local notif = Create("Frame", {
        Name = "Notif_" .. NotificationCount,
        BackgroundColor3 = Theme.Surface,
        Size = UDim2.new(1, 0, 0, 72),
        BackgroundTransparency = 0,
        ClipsDescendants = true,
        Parent = NotifHolder
    })
    MakeCorner(10, notif)
    MakeStroke(Theme.Border, 1, notif)

    local accent = Create("Frame", {
        Name = "Accent",
        BackgroundColor3 = accentColor,
        Size = UDim2.new(0, 3, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        Parent = notif
    })
    MakeCorner(3, accent)

    Create("TextLabel", {
        Name = "Title",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 10),
        Size = UDim2.new(1, -16, 0, 20),
        Text = title,
        TextColor3 = Theme.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notif
    })

    Create("TextLabel", {
        Name = "Desc",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 32),
        Size = UDim2.new(1, -24, 0, 30),
        Text = desc,
        TextColor3 = Theme.TextSecondary,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = notif
    })

    local prog = Create("Frame", {
        Name = "Progress",
        BackgroundColor3 = accentColor,
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundTransparency = 0.4,
        Parent = notif
    })

    notif.Position = UDim2.new(1, 20, 0, 0)
    Tween(notif, { Position = UDim2.new(0, 0, 0, 0) }, 0.4, Enum.EasingStyle.Expo)
    Tween(prog, { Size = UDim2.new(0, 0, 0, 2) }, duration, Enum.EasingStyle.Linear)

    task.delay(duration, function()
        Tween(notif, { Position = UDim2.new(1, 20, 0, 0) }, 0.35, Enum.EasingStyle.Expo)
        task.delay(0.4, function()
            notif:Destroy()
        end)
    end)

    return notif
end

