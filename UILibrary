                local stroke = inputFrame:FindFirstChildOfClass("UIStroke")
                if stroke then Tween(stroke, { Color = Theme.Accent }, 0.15) end
            end)
            textBox.FocusLost:Connect(function(enter)
                Tween(inputFrame, { BackgroundColor3 = Theme.Background }, 0.15)
                local stroke = inputFrame:FindFirstChildOfClass("UIStroke")
                if stroke then Tween(stroke, { Color = Theme.Border }, 0.15) end
                if enter then
                    task.spawn(callback, textBox.Text)
                end
            end)

            return textBox
        end

        -- ========== LABEL ==========
        function SectionAPI:AddLabel(lopts)
            lopts = lopts or {}
            local text = lopts.Text or "Label"
            local color = lopts.Color or Theme.TextSecondary

            local lbl = Create("TextLabel", {
                Name = "Label",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 24),
                LayoutOrder = self:_nextOrder(),
                Text = text,
                TextColor3 = color,
                Font = Enum.Font.Gotham,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true,
                Parent = self._frame
            })

            local LabelAPI = {}
            function LabelAPI:SetText(t)
                lbl.Text = t
            end
            function LabelAPI:SetColor(c)
                Tween(lbl, { TextColor3 = c }, 0.2)
            end
            return LabelAPI
        end

        -- ========== SEPARATOR ==========
        function SectionAPI:AddSeparator()
            Create("Frame", {
                Name = "Sep",
                BackgroundColor3 = Theme.Border,
                Size = UDim2.new(1, 0, 0, 1),
                LayoutOrder = self:_nextOrder(),
                Parent = self._frame
            })
        end

        -- ========== COLOR PICKER (accent) ==========
        function SectionAPI:AddColorPicker(copts)
            copts = copts or {}
            local name = copts.Name or "Accent Color"
            local colors = copts.Colors or {
                Color3.fromRGB(108, 92, 231),
                Color3.fromRGB(239, 68, 68),
                Color3.fromRGB(34, 197, 94),
                Color3.fromRGB(59, 130, 246),
                Color3.fromRGB(251, 146, 60),
                Color3.fromRGB(236, 72, 153),
                Color3.fromRGB(14, 165, 233),
                Color3.fromRGB(168, 85, 247),
            }
            local callback = copts.Callback or function() end

            local container = Create("Frame", {
                Name = "ColorPickerContainer",
                BackgroundColor3 = Theme.SurfaceAlt,
                Size = UDim2.new(1, 0, 0, 60),
                LayoutOrder = self:_nextOrder(),
                Parent = self._frame
            })
            MakeCorner(8, container)
            MakeStroke(Theme.Border, 1, container)
            MakePadding(8, 8, 12, 12, container)
            Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 6),
                Parent = container
            })

            Create("TextLabel", {
                Name = "CPLabel",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 16),
                LayoutOrder = 1,
                Text = name,
                TextColor3 = Theme.Text,
                Font = Enum.Font.GothamBold,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = container
            })

            local swatchRow = Create("Frame", {
                Name = "Swatches",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 22),
                LayoutOrder = 2,
                Parent = container
            })
            Create("UIListLayout", {
                FillDirection = Enum.FillDirection.Horizontal,
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 6),
                Parent = swatchRow
            })

            for _, c in ipairs(colors) do
                local swatch = Create("TextButton", {
                    Name = "Swatch",
                    BackgroundColor3 = c,
                    Size = UDim2.new(0, 22, 0, 22),
                    Text = "",
                    Parent = swatchRow
                })
                MakeCorner(4, swatch)

                swatch.MouseButton1Click:Connect(function()
                    self._window:SetTheme(c)
                    task.spawn(callback, c)
                end)
                swatch.MouseEnter:Connect(function()
                    Tween(swatch, { Size = UDim2.new(0, 24, 0, 24) }, 0.1)
                end)
                swatch.MouseLeave:Connect(function()
                    Tween(swatch, { Size = UDim2.new(0, 22, 0, 22) }, 0.1)
                end)
            end
        end

        return SectionAPI
    end

    return TabAPI
end

function Window:SelectTab(tab)
    -- Deactivate current
    if self.ActiveTab then
        local prev = self.ActiveTab
        Tween(prev.Button, { BackgroundColor3 = Theme.SurfaceAlt, BackgroundTransparency = 1 }, 0.2)
        Tween(prev.Label, { TextColor3 = Theme.TextSecondary }, 0.2)
        Tween(prev.Indicator, { BackgroundTransparency = 1 }, 0.2)
        prev.Page.Visible = false
    end

    self.ActiveTab = tab

    Tween(tab.Button, { BackgroundColor3 = Theme.AccentDim, BackgroundTransparency = 0 }, 0.2)
    Tween(tab.Label, { TextColor3 = Theme.White }, 0.2)
    Tween(tab.Indicator, { BackgroundTransparency = 0 }, 0.2)
    tab.Label.Font = Enum.Font.GothamBold

    tab.Page.Visible = true
    tab.Page.BackgroundTransparency = 1
    Tween(tab.Page, { BackgroundTransparency = 0 }, 0.2)
end

